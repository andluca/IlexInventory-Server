# Copy this file to .env and fill in real values.
# The .env file is in .gitignore — never commit secrets.

# Django secret key (required by Django framework).
# Generate a real one with: python -c "from django.core.signing import get_cookie_signer; print(get_cookie_signer().key)"
# or: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=dev-secret-do-not-use-in-prod

# Postgres URL for the dev server (runserver / wsgi).
# Tests default to ilex_test (see backend/conftest.py); dev server uses ilex_dev.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ilex_dev
