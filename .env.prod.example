# Production environment variables — copy to .env.prod and fill in real values.
# .env.prod is gitignored; this file is committed as documentation.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=postgresql://ilex:change-me@localhost:5432/ilex_prod
ALLOWED_HOSTS=ilex-inventory-server.fly.dev
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Optional — defaults applied if absent
OPENAPI_PUBLIC_DOCS=false
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# Postgres service (used by docker-compose.prod.yml)
POSTGRES_USER=ilex
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ilex_prod
